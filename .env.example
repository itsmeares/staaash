# ── Storage ──────────────────────────────────────────────────────────────────
# The location where your uploaded files are stored
UPLOAD_LOCATION=./library

# The location where your database files are stored
DB_DATA_LOCATION=./postgres

# ── Version ──────────────────────────────────────────────────────────────────
# Staaash version — use a pinned version (e.g. v1.2.3) if you'd like.
STAAASH_VERSION=latest

# ── Database - Not Recommended to Change ─────────────────────────────────────
DB_USERNAME=postgres
DB_DATABASE_NAME=staaash

# Change this — it is the Postgres connection password
# Use only A-Za-z0-9 characters — no special characters or spaces
DB_PASSWORD=change-me
