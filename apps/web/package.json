{
  "name": "web",
  "version": "0.2.0-beta.1",
  "private": true,
  "scripts": {
    "build:deps": "pnpm --filter @staaash/config build && pnpm --filter @staaash/db build",
    "predev": "pnpm run build:deps",
    "prebuild": "pnpm run build:deps",
    "prelint": "pnpm run build:deps && next typegen",
    "pretest": "pnpm run build:deps",
    "pretypecheck": "pnpm run build:deps && next typegen",
    "dev": "next dev",
    "e2e:prepare": "node scripts/e2e-bootstrap.mjs",
    "build": "next build",
    "start": "next start",
    "lint": "tsc --noEmit --incremental false -p tsconfig.json",
    "typecheck": "tsc --noEmit --incremental false -p tsconfig.json",
    "test": "vitest run",
    "e2e": "playwright test"
  },
  "dependencies": {
    "@base-ui/react": "^1.4.1",
    "@react-three/fiber": "^9.6.1",
    "@staaash/config": "workspace:*",
    "@staaash/db": "workspace:*",
    "canvas-confetti": "^1.9.4",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "heic-convert": "^2.1.0",
    "lucide-react": "^1.16.0",
    "next": "16.2.6",
    "next-themes": "^0.4.6",
    "react": "19.2.6",
    "react-dom": "19.2.6",
    "shadcn": "^4.7.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "three": "^0.184.0",
    "tw-animate-css": "^1.4.0",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/canvas-confetti": "^1.9.0",
    "@types/node": "^20.19.41",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/yazl": "^3.3.1",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
