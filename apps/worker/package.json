{
  "name": "worker",
  "version": "0.2.0-beta.3",
  "private": true,
  "type": "module",
  "scripts": {
    "build:deps": "pnpm --filter @staaash/config build && pnpm --filter @staaash/db build",
    "predev": "pnpm run build:deps",
    "prebuild": "pnpm run build:deps",
    "prelint": "pnpm run build:deps",
    "pretest": "pnpm run build:deps",
    "pretypecheck": "pnpm run build:deps",
    "dev": "node --env-file=../../.env.local --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@staaash/config": "workspace:*",
    "@staaash/db": "workspace:*",
    "tsx": "^4.22.1",
    "yazl": "^3.3.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^20.19.41",
    "@types/yazl": "^3.3.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
