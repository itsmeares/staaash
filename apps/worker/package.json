{
  "name": "worker",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "predev": "pnpm --filter @staaash/config build",
    "prebuild": "pnpm --filter @staaash/config build",
    "prelint": "pnpm --filter @staaash/config build",
    "pretest": "pnpm --filter @staaash/config build",
    "pretypecheck": "pnpm --filter @staaash/config build",
    "dev": "node --env-file=../../.env --import tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "dependencies": {
    "@staaash/config": "workspace:*",
    "@staaash/db": "workspace:*",
    "@types/fluent-ffmpeg": "^2.1.28",
    "fluent-ffmpeg": "^2.1.3",
    "music-metadata": "^11.12.3",
    "sharp": "^0.34.5",
    "tsx": "^4.20.6",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
