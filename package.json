{
  "name": "staaash",
  "version": "1.0.0-rc.4",
  "description": "Self-hosted personal cloud drive monorepo.",
  "private": true,
  "license": "AGPL-3.0-only",
  "packageManager": "pnpm@11.9.0+sha512.bd682d5d03fe525ef7c9fd6780c6884d1e756ac4c9c9fe00c538782824310dcf90e3ddc4f53835f06dfaebd5085e41855e0bcbb3b60de2ac5bbab89e5036f03b",
  "scripts": {
    "web:dev": "pnpm --filter web dev",
    "worker:dev": "pnpm --filter worker dev",
    "web:build": "pnpm --filter web build",
    "worker:build": "pnpm --filter worker build",
    "web:test": "pnpm --filter web test",
    "web:e2e": "pnpm --filter web e2e",
    "worker:test": "pnpm --filter worker test",
    "web:lint": "pnpm --filter web lint",
    "worker:lint": "pnpm --filter worker lint",
    "db:build": "pnpm --filter @staaash/db build",
    "db:test": "pnpm --filter @staaash/db test",
    "db:lint": "pnpm --filter @staaash/db lint",
    "build": "turbo build",
    "lint": "turbo lint",
    "typecheck": "turbo typecheck",
    "test": "turbo test",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky",
    "db:generate": "pnpm --filter @staaash/db db:generate",
    "db:push": "pnpm --filter @staaash/db exec prisma db push",
    "app:clear-caches": "node scripts/clear-caches.mjs",
    "app:reset-local-data": "node scripts/reset-local-data.mjs",
    "quality:fallow": "fallow audit --base origin/main --gate new-only --production-dead-code --production-health --production-dupes --no-css --max-crap 60 --health-baseline .fallow/baselines/health.json"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css}": "prettier --write --ignore-unknown"
  },
  "dependencies": {
    "pg": "^8.22.0"
  },
  "devDependencies": {
    "fallow": "3.3.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "prettier": "3.9.0",
    "turbo": "^2.10.0",
    "typescript": "^6.0.3"
  }
}
