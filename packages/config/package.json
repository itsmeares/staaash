{
  "name": "@staaash/config",
  "version": "1.0.0-rc.2",
  "private": true,
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./runtime-paths": {
      "types": "./dist/runtime-paths.d.ts",
      "default": "./dist/runtime-paths.js"
    },
    "./time-zone": {
      "types": "./dist/time-zone.d.ts",
      "default": "./dist/time-zone.js"
    }
  },
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "lint": "tsc --noEmit -p tsconfig.json",
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "test": "vitest run --passWithNoTests"
  },
  "devDependencies": {
    "@types/node": "^24.13.2",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  }
}
