generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum JobStatus {
  queued
  running
  succeeded
  failed
  dead
  cancelled
}

enum RestoreReconciliationStatus {
  queued
  running
  succeeded
  failed
}

enum ShareTargetType {
  file
  folder
}

enum FileStorageStatus {
  available
  missing
}

model Instance {
  id                     String    @id @default("singleton")
  name                   String
  authSecret             String?
  setupCompletedAt       DateTime  @default(now())
  lastUpdateCheckAt      DateTime?
  updateCheckStatus      String?
  updateCheckMessage     String?
  latestAvailableVersion String?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model SystemSettings {
  id                            String   @id @default("singleton")
  sessionMaxAgeDays             Int      @default(30)
  shareMaxAgeDays               Int      @default(30)
  maxUploadBytes                BigInt   @default(10737418240)
  uploadTimeoutMinutes          Int      @default(60)
  uploadStagingRetentionHours   Int      @default(2)
  previewMaxSourceBytes         Int      @default(26214400)
  previewTextMaxBytes           Int      @default(65536)
  workerHeartbeatMaxAgeSeconds  Int      @default(120)
  updateCheckIntervalHours      Int      @default(24)
  updateCheckRepository         String   @default("itsmeares/staaash")
  timeZone                      String   @default("UTC")
  maintenanceRunTime            String   @default("02:00")
  mediaPreviewEnabled           Boolean  @default(true)
  mediaPreviewGenerateOnUpload  Boolean  @default(false)
  mediaPreviewThresholdBytes    BigInt   @default(367001600)
  mediaPreviewRetentionDays     Int      @default(14)
  mediaPreviewMaxHeight         Int      @default(1080)
  zipArchiveRetentionDays       Int      @default(7)
  mediaPreviewCrf               Int      @default(22)
  mediaPreviewMaxConcurrentJobs Int      @default(1)
  createdAt                     DateTime @default(now())
  updatedAt                     DateTime @updatedAt
}

model User {
  id                        String                     @id @default(cuid())
  email                     String                     @unique
  storageId                 String                     @unique
  displayName               String?
  avatarUrl                 String?
  passwordHash              String
  isOwner                   Boolean                    @default(false)
  isAdmin                   Boolean                    @default(false)
  passwordChangeRequiredAt  DateTime?
  temporaryPasswordIssuedAt DateTime?
  temporaryPasswordIssuedByUserId String?
  storageLimitBytes         BigInt?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  sessions                  Session[]
  preferences               UserPreference?
  folders                   Folder[]                   @relation("FolderOwner")
  files                     File[]                     @relation("FileOwner")
  favoriteFiles             FavoriteFile[]
  favoriteFolders           FavoriteFolder[]
  recentFiles               RecentFile[]
  recentFolders             RecentFolder[]
  shareLinks                ShareLink[]                @relation("ShareLinkCreator")
  restoreReconciliationRuns RestoreReconciliationRun[] @relation("RestoreReconciliationTrigger")
  zipArchives               ZipArchive[]

  @@index([isOwner])
  @@index([isAdmin])
}

model UserPreference {
  id                      String    @id @default(cuid())
  userId                  String    @unique
  theme                   String    @default("system")
  timeZone                String    @default("UTC")
  showUpdateNotifications Boolean   @default(true)
  enableVersionChecks     Boolean   @default(true)
  onboardingCompletedAt   DateTime?
  createdAt               DateTime  @default(now())
  updatedAt               DateTime  @updatedAt
  user                    User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Session {
  id         String    @id @default(cuid())
  userId     String
  tokenHash  String    @unique
  expiresAt  DateTime
  revokedAt  DateTime?
  userAgent  String?
  ipAddress  String?
  lastSeenAt DateTime?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
  user       User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Folder {
  id          String           @id @default(cuid())
  ownerUserId String
  parentId    String?
  name        String
  isFilesRoot Boolean          @default(false)
  deletedAt   DateTime?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt
  owner       User             @relation("FolderOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  parent      Folder?          @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    Folder[]         @relation("FolderHierarchy")
  files       File[]
  favorites   FavoriteFolder[]
  recents     RecentFolder[]
  shareLink   ShareLink?       @relation("ShareLinkFolder")

  @@index([ownerUserId, isFilesRoot])
  @@index([ownerUserId, parentId, deletedAt])
  @@index([ownerUserId, deletedAt, updatedAt])
}

model File {
  id               String            @id @default(cuid())
  ownerUserId      String
  folderId         String?
  originalName     String
  storageKey       String            @unique
  storageStatus    FileStorageStatus @default(available)
  storageCheckedAt DateTime?
  storageMissingAt DateTime?
  mimeType         String
  sizeBytes        BigInt
  contentChecksum  String?
  deletedAt        DateTime?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  owner            User              @relation("FileOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  folder           Folder?           @relation(fields: [folderId], references: [id], onDelete: SetNull)
  favorites        FavoriteFile[]
  recents          RecentFile[]
  shareLink        ShareLink?        @relation("ShareLinkFile")
  derivatives      MediaDerivative[]

  @@index([ownerUserId, folderId, deletedAt])
  @@index([ownerUserId, folderId, deletedAt, storageStatus])
}

model FavoriteFile {
  id                  String    @id @default(cuid())
  userId              String
  fileId              String
  createdAt           DateTime  @default(now())
  quickAccessPinnedAt DateTime?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  file                File      @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId, createdAt])
  @@index([userId, quickAccessPinnedAt])
}

model FavoriteFolder {
  id                  String    @id @default(cuid())
  userId              String
  folderId            String
  createdAt           DateTime  @default(now())
  quickAccessPinnedAt DateTime?
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder              Folder    @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([userId, folderId])
  @@index([userId, createdAt])
  @@index([userId, quickAccessPinnedAt])
}

model RecentFile {
  id               String   @id @default(cuid())
  userId           String
  fileId           String
  lastInteractedAt DateTime
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file             File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId, lastInteractedAt])
}

model RecentFolder {
  id               String   @id @default(cuid())
  userId           String
  folderId         String
  lastInteractedAt DateTime
  user             User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder           Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([userId, folderId])
  @@index([userId, lastInteractedAt])
}

model ShareLink {
  id               String          @id @default(cuid())
  createdByUserId  String
  targetType       ShareTargetType
  fileId           String?
  folderId         String?
  tokenLookupKey   String          @unique
  tokenHash        String          @unique
  passwordHash     String?
  downloadDisabled Boolean         @default(false)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        User            @relation("ShareLinkCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  file             File?           @relation("ShareLinkFile", fields: [fileId], references: [id], onDelete: Cascade)
  folder           Folder?         @relation("ShareLinkFolder", fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([fileId])
  @@unique([folderId])
  @@index([createdByUserId, revokedAt, expiresAt])
}

model BackgroundJob {
  id                String               @id @default(cuid())
  kind              String
  queueName         String               @default("default")
  priority          Int                  @default(0)
  status            JobStatus            @default(queued)
  payloadJson       Json
  progressJson      Json                 @default("{}")
  dedupeKey         String?
  runAt             DateTime             @default(now())
  lockedAt          DateTime?
  lockedBy          String?
  leaseExpiresAt    DateTime?
  timeoutAt         DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  cancelledByUserId String?
  attemptCount      Int                  @default(0)
  maxAttempts       Int                  @default(5)
  lastError         String?
  errorCode         String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  events            BackgroundJobEvent[]

  @@index([status, runAt])
  @@index([kind, dedupeKey, status])
  @@index([status, queueName, priority, runAt])
  @@index([lockedBy, leaseExpiresAt])
  @@index([kind, status, runAt])
}

model WorkerInstance {
  id              String    @id
  hostname        String
  pid             Int
  version         String?
  startedAt       DateTime  @default(now())
  lastHeartbeatAt DateTime  @default(now())
  stoppedAt       DateTime?
  status          String
  currentJobId    String?
  metadataJson    Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  @@index([status])
  @@index([lastHeartbeatAt])
}

model BackgroundJobEvent {
  id           String        @id @default(cuid())
  jobId        String
  type         String
  message      String?
  metadataJson Json          @default("{}")
  workerId     String?
  createdAt    DateTime      @default(now())
  job          BackgroundJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([type])
}

model RestoreReconciliationRun {
  id                   String                      @id @default(cuid())
  status               RestoreReconciliationStatus @default(queued)
  triggeredByUserId    String?
  backgroundJobId      String?                     @unique
  startedAt            DateTime?
  completedAt          DateTime?
  missingOriginalCount Int                         @default(0)
  orphanedStorageCount Int                         @default(0)
  detailsJson          Json?
  lastError            String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  triggeredBy          User?                       @relation("RestoreReconciliationTrigger", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([createdAt])
}

model MediaDerivative {
  id              String    @id @default(cuid())
  fileId          String
  kind            String
  profile         String
  status          String
  storageKey      String?   @unique
  mimeType        String?
  sizeBytes       BigInt?
  width           Int?
  height          Int?
  durationSeconds Float?
  videoCodec      String?
  audioCodec      String?
  error           String?
  pinnedByAdmin   Boolean   @default(false)
  lastViewedAt    DateTime?
  lastSharedAt    DateTime?
  generatedAt     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  file File @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([fileId, kind, profile])
  @@index([status, updatedAt])
  @@index([pinnedByAdmin, lastViewedAt])
}

model ZipArchive {
  id         String   @id @default(cuid())
  userId     String
  contentKey String   @unique
  idsJson    Json
  status     String
  storageKey String?  @unique
  fileName   String?
  sizeBytes  BigInt?
  fileCount  Int?
  error      String?
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([expiresAt])
}

model UploadSession {
  id               String        @id @default(cuid())
  ownerUserId      String
  folderId         String?
  originalName     String
  mimeType         String
  totalSizeBytes   BigInt
  receivedBytes    BigInt        @default(0)
  expectedChecksum String?
  protocolVersion  Int           @default(1)
  chunkSizeBytes   BigInt?
  tmpPath          String
  conflictStrategy String
  status           String
  expiresAt        DateTime
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  chunks           UploadChunk[]

  @@index([ownerUserId, status])
  @@index([expiresAt, status])
}

model UploadChunk {
  id          String        @id @default(cuid())
  sessionId   String
  chunkIndex  Int
  startByte   BigInt
  endByte     BigInt
  sizeBytes   BigInt
  completedAt DateTime      @default(now())
  session     UploadSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@unique([sessionId, chunkIndex])
  @@index([sessionId])
}
