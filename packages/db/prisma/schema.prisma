generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  owner
  member
}

enum JobStatus {
  queued
  running
  succeeded
  failed
  dead
}

enum RestoreReconciliationStatus {
  queued
  running
  succeeded
  failed
}

enum ShareTargetType {
  file
  folder
}

model Instance {
  id                    String    @id @default("singleton")
  name                  String
  setupCompletedAt      DateTime  @default(now())
  lastUpdateCheckAt     DateTime?
  updateCheckStatus     String?
  updateCheckMessage    String?
  latestAvailableVersion String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
}

model User {
  id                    String          @id @default(cuid())
  email                 String          @unique
  username              String          @unique
  displayName           String?
  passwordHash          String
  role                  UserRole        @default(member)
  storageLimitBytes     BigInt?
  createdAt             DateTime        @default(now())
  updatedAt             DateTime        @updatedAt
  sessions              Session[]
  invitesIssued         Invite[]        @relation("InviteIssuer")
  invitesAccepted       Invite[]        @relation("InviteAcceptor")
  passwordResetsIssued  PasswordReset[] @relation("PasswordResetIssuer")
  passwordResetsForUser PasswordReset[] @relation("PasswordResetUser")
  folders               Folder[]        @relation("FolderOwner")
  files                 File[]          @relation("FileOwner")
  favoriteFiles         FavoriteFile[]
  favoriteFolders       FavoriteFolder[]
  recentFiles           RecentFile[]
  recentFolders         RecentFolder[]
  shareLinks            ShareLink[]     @relation("ShareLinkCreator")
  restoreReconciliationRuns RestoreReconciliationRun[] @relation("RestoreReconciliationTrigger")
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  tokenHash String   @unique
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, expiresAt])
}

model Invite {
  id               String    @id @default(cuid())
  email            String
  role             UserRole  @default(member)
  tokenHash        String    @unique
  invitedByUserId  String
  acceptedByUserId String?
  acceptedAt       DateTime?
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  invitedBy        User      @relation("InviteIssuer", fields: [invitedByUserId], references: [id], onDelete: Restrict)
  acceptedBy       User?     @relation("InviteAcceptor", fields: [acceptedByUserId], references: [id], onDelete: SetNull)

  @@index([email, revokedAt, expiresAt])
}

model PasswordReset {
  id             String   @id @default(cuid())
  userId         String
  issuedByUserId String
  tokenHash      String   @unique
  expiresAt      DateTime
  redeemedAt     DateTime?
  revokedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  user           User     @relation("PasswordResetUser", fields: [userId], references: [id], onDelete: Cascade)
  issuedBy       User     @relation("PasswordResetIssuer", fields: [issuedByUserId], references: [id], onDelete: Restrict)

  @@index([userId, revokedAt, expiresAt])
}

model Folder {
  id             String   @id @default(cuid())
  ownerUserId    String
  parentId       String?
  name           String
  isFilesRoot    Boolean  @default(false)
  deletedAt      DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  owner          User     @relation("FolderOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  parent         Folder?  @relation("FolderHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children       Folder[] @relation("FolderHierarchy")
  files          File[]
  favorites      FavoriteFolder[]
  recents        RecentFolder[]
  shareLink      ShareLink? @relation("ShareLinkFolder")

  @@index([ownerUserId, isFilesRoot])
  @@index([ownerUserId, parentId, deletedAt])
  @@index([ownerUserId, deletedAt, updatedAt])
}

model File {
  id               String        @id @default(cuid())
  ownerUserId      String
  folderId         String?
  originalName     String
  storageKey       String        @unique
  mimeType         String
  sizeBytes        BigInt
  contentChecksum  String?
  deletedAt        DateTime?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  owner            User          @relation("FileOwner", fields: [ownerUserId], references: [id], onDelete: Cascade)
  folder           Folder?       @relation(fields: [folderId], references: [id], onDelete: SetNull)
  favorites        FavoriteFile[]
  recents          RecentFile[]
  shareLink        ShareLink?    @relation("ShareLinkFile")

  @@index([ownerUserId, folderId, deletedAt])
}

model FavoriteFile {
  id        String   @id @default(cuid())
  userId    String
  fileId    String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file      File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId, createdAt])
}

model FavoriteFolder {
  id        String   @id @default(cuid())
  userId    String
  folderId  String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder    Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([userId, folderId])
  @@index([userId, createdAt])
}

model RecentFile {
  id                String   @id @default(cuid())
  userId            String
  fileId            String
  lastInteractedAt  DateTime
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  file              File     @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@unique([userId, fileId])
  @@index([userId, lastInteractedAt])
}

model RecentFolder {
  id                String   @id @default(cuid())
  userId            String
  folderId          String
  lastInteractedAt  DateTime
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  folder            Folder   @relation(fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([userId, folderId])
  @@index([userId, lastInteractedAt])
}

model ShareLink {
  id               String          @id @default(cuid())
  createdByUserId  String
  targetType       ShareTargetType
  fileId           String?
  folderId         String?
  tokenLookupKey   String          @unique
  tokenHash        String          @unique
  passwordHash     String?
  downloadDisabled Boolean         @default(false)
  expiresAt        DateTime
  revokedAt        DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  createdBy        User            @relation("ShareLinkCreator", fields: [createdByUserId], references: [id], onDelete: Cascade)
  file             File?           @relation("ShareLinkFile", fields: [fileId], references: [id], onDelete: Cascade)
  folder           Folder?         @relation("ShareLinkFolder", fields: [folderId], references: [id], onDelete: Cascade)

  @@unique([fileId])
  @@unique([folderId])
  @@index([createdByUserId, revokedAt, expiresAt])
}

model BackgroundJob {
  id           String    @id @default(cuid())
  kind         String
  status       JobStatus @default(queued)
  payloadJson  Json
  dedupeKey    String?
  runAt        DateTime  @default(now())
  lockedAt     DateTime?
  lockedBy     String?
  attemptCount Int       @default(0)
  maxAttempts  Int       @default(5)
  lastError    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  @@index([status, runAt])
  @@index([kind, dedupeKey, status])
}

model RestoreReconciliationRun {
  id                   String                      @id @default(cuid())
  status               RestoreReconciliationStatus @default(queued)
  triggeredByUserId    String?
  backgroundJobId      String?                     @unique
  startedAt            DateTime?
  completedAt          DateTime?
  missingOriginalCount Int                         @default(0)
  orphanedStorageCount Int                         @default(0)
  detailsJson          Json?
  lastError            String?
  createdAt            DateTime                    @default(now())
  updatedAt            DateTime                    @updatedAt
  triggeredBy          User?                       @relation("RestoreReconciliationTrigger", fields: [triggeredByUserId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
  @@index([createdAt])
}
