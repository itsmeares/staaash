{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended", "mergeConfidence:all-badges"],
  "dependencyDashboard": true,
  "timezone": "Europe/London",
  "schedule": ["* 0-3 * * 1"],
  "minimumReleaseAge": "1 day",
  "rangeStrategy": "bump",
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["* 0-3 * * 1"]
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "groupName": "Major Updates"
    },
    {
      "matchManagers": ["github-actions"],
      "groupName": "GitHub Actions"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["node"],
      "allowedVersions": "24"
    },
    {
      "matchPackageNames": ["next", "react", "react-dom"],
      "groupName": "Next and React"
    },
    {
      "matchPackageNames": ["@prisma/client", "prisma", "@prisma/adapter-pg"],
      "groupName": "Prisma"
    },
    {
      "matchPackageNames": ["typescript", "vitest", "@types/node"],
      "groupName": "TypeScript tooling"
    },
    {
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["patch", "minor"],
      "groupName": "dev dependencies"
    },
    {
      "matchDatasources": ["docker"],
      "matchPackageNames": ["postgres"],
      "matchUpdateTypes": ["major"],
      "enabled": false
    }
  ]
}
